{
  "name": "boilerplate",
  "version": "0.1.0",
  "private": true,
  "description": "Spec-first monorepo boilerplate — {{APP_NAME}}",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,vue,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,vue,json,md,yaml,yml}\"",
    "stylelint": "stylelint \"{apps/web,packages/ui}/**/*.{vue,scss,css}\"",
    "stylelint:fix": "stylelint --fix \"{apps/web,packages/ui}/**/*.{vue,scss,css}\"",
    "spec:validate": "turbo run validate --filter=@app/specs",
    "spec:bundle": "turbo run bundle --filter=@app/specs",
    "spec:codegen": "turbo run codegen --filter=@app/specs",
    "spec:contract-test": "turbo run contract-test --filter=@app/specs",
    "spec:diff": "pnpm --filter @app/specs diff",
    "design:build": "pnpm --filter @app/design-tokens build",
    "design:audit": "pnpm --filter @app/design-tokens audit:inventory",
    "storybook": "pnpm --filter @app/ui storybook",
    "storybook:build": "pnpm --filter @app/ui storybook:build",
    "prepare": "husky",
    "check:i18n": "node --experimental-strip-types scripts/check-i18n-parity.ts"
  },
  "devDependencies": {
    "@app/eslint-config": "workspace:*",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "postcss-html": "^1.8.0",
    "postcss-scss": "^4.0.9",
    "stylelint": "^17.8.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{vue,scss,css}": [
      "stylelint --fix --allow-empty-input"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "packages/specs/openapi/**/*.{yaml,yml}": [
      "pnpm --filter @app/specs validate"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/engines",
      "@sentry-internal/node-cpu-profiler",
      "@swc/core",
      "esbuild",
      "prisma",
      "protobufjs"
    ],
    "overrides": {
      "@babel/core@7.12.9": "^7.29.0",
      "vue-router": "^5.0.4",
      "next": ">=15.2.3",
      "handlebars": "4.7.9",
      "lodash": "4.18.1",
      "@tailwindcss/vite": "4.2.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "next>react": "19",
        "next>react-dom": "19",
        "c12>magicast": "0.5",
        "@nuxt/test-utils>vitest": "4",
        "vitest-environment-nuxt>vitest": "4",
        "@nuxt/ui>vue-router": "5",
        "@nuxtjs/i18n>vue-router": "5",
        "unplugin-vue-router>vue-router": "5"
      }
    }
  }
}
