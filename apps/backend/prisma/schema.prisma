// Prisma schema — Better Auth tables are generated by
// `pnpm --filter @app/backend auth:generate-schema` and merged here.
// Add domain models below the auth section.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ----- Better Auth -----

model User {
  id                  String    @id
  name                String
  email               String    @unique
  emailVerified       Boolean
  image               String?
  createdAt           DateTime
  updatedAt           DateTime
  phoneNumber         String?   @unique
  phoneNumberVerified Boolean?
  // Better Auth `admin` plugin
  role                String    @default("USER")
  banned              Boolean   @default(false)
  banReason           String?
  banExpires          DateTime?
  // additionalFields (auth.service.ts)
  displayName         String?
  sessions            Session[]
  accounts            Account[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Better Auth `admin` plugin — set when an admin impersonates a user
  impersonatedBy String?

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ----- Domain -----

model Library {
  id        String   @id @default(cuid())
  name      String
  rootPath  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("library")
}

// ----- Scan -----

enum ScanStatus {
  running
  succeeded
  failed
  cancelled
}

model Scan {
  id                String     @id @default(cuid())
  libraryId         String
  status            ScanStatus
  startedAt         DateTime   @default(now())
  finishedAt        DateTime?
  filesScanned      Int        @default(0)
  filesAdded        Int        @default(0)
  filesUpdated      Int        @default(0)
  coursesDiscovered Int        @default(0)
  errors            ScanErrorRecord[]
  discoveredFiles   DiscoveredFile[]

  @@index([libraryId, status])
  @@index([libraryId, startedAt])
  @@map("scan")
}

model ScanErrorRecord {
  id      String  @id @default(cuid())
  scanId  String
  scan    Scan    @relation(fields: [scanId], references: [id], onDelete: Cascade)
  path    String
  message String
  code    String?

  @@map("scan_error")
}

model DiscoveredFile {
  id     String   @id @default(cuid())
  scanId String
  scan   Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  path   String
  mtime  DateTime
  size   Int

  @@unique([scanId, path])
  @@map("discovered_file")
}

// ----- Course -----

model Course {
  id          String    @id @default(cuid())
  libraryId   String
  slug        String
  title       String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sections    Section[]

  @@unique([libraryId, slug], name: "uq_course_library_slug")
  @@index([libraryId])
  @@map("course")
}

model Section {
  id       String   @id @default(cuid())
  courseId String
  position Int
  title    String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@unique([courseId, position], name: "uq_section_course_position")
  @@map("section")
}

// ----- Lesson -----

enum MaterialKind {
  doc
  note
  image
  slide
}

model Lesson {
  id          String     @id @default(cuid())
  courseId    String
  sectionId   String
  position    Int
  title       String
  videoPath   String
  mtime       DateTime
  sizeBytes   Int
  duration    Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  materials   Material[]
  subtitles   Subtitle[]
  section     Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, position], name: "uq_lesson_section_position")
  @@index([courseId, sectionId])
  @@map("lesson")
}

model Material {
  id        String       @id @default(cuid())
  lessonId  String
  kind      MaterialKind
  label     String
  path      String
  sizeBytes Int
  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("material")
}

model Subtitle {
  id       String @id @default(cuid())
  lessonId String
  language String
  label    String
  path     String
  lesson   Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("subtitle")
}

// ----- Learning -----

model LessonProgress {
  id              String    @id @default(cuid())
  userId          String
  lessonId        String
  positionSeconds Int
  durationSeconds Int
  percent         Int       // 0..100, integer for index efficiency; client computes float on display
  completed       Boolean   @default(false)
  lastSeenAt      DateTime
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())

  @@unique([userId, lessonId], name: "uq_lesson_progress_user_lesson")
  @@index([userId])
  @@map("lesson_progress")
}

// ----- CourseProgressReadModel -----

model CourseProgressReadModel {
  id               String   @id @default(cuid())
  userId           String
  courseId         String
  lessonsCompleted Int      @default(0)
  lessonsTotal     Int      @default(0)
  percent          Int      @default(0) // 0..100
  lastSeenAt       DateTime
  lastSeenLessonId String
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  @@unique([userId, courseId], name: "uq_course_progress_user_course")
  @@index([userId, lastSeenAt(sort: Desc)])
  @@map("course_progress_read_model")
}

// ----- Bookmark -----

model Bookmark {
  id              String   @id @default(cuid())
  userId          String
  lessonId        String
  positionSeconds Int
  label           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, lessonId])
  @@index([userId, id])
  @@map("bookmark")
}

// ----- Note -----

model Note {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId], name: "uq_note_user_lesson")
  @@index([userId])
  @@map("note")
}

// ----- Access -----

enum GrantTargetKind {
  library
  course
}

enum GrantLevel {
  READ
}

model AccessGrant {
  id         String          @id @default(cuid())
  userId     String
  targetKind GrantTargetKind
  libraryId  String?
  courseId   String?
  level      GrantLevel
  createdAt  DateTime        @default(now())

  @@unique([userId, targetKind, libraryId, courseId], name: "uq_grant_target")
  @@index([userId])
  @@map("access_grant")
}
