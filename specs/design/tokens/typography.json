{
  "$description": "Typography tokens. Default font stack is Inter. Replace with your brand typeface.",
  "typography": {
    "font": {
      "family": {
        "sans": {
          "$value": "'IBM Plex Sans', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
          "$type": "fontFamily"
        },
        "mono": {
          "$value": "'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
          "$type": "fontFamily"
        }
      },
      "weight": {
        "regular": { "$value": 400, "$type": "fontWeight" },
        "medium": { "$value": 500, "$type": "fontWeight" },
        "semibold": { "$value": 600, "$type": "fontWeight" },
        "bold": { "$value": 700, "$type": "fontWeight" }
      },
      "size": {
        "xs": { "$value": "11px", "$type": "dimension" },
        "sm": { "$value": "12px", "$type": "dimension" },
        "md": { "$value": "14px", "$type": "dimension" },
        "base": { "$value": "16px", "$type": "dimension" },
        "lg": { "$value": "18px", "$type": "dimension" },
        "xl": { "$value": "20px", "$type": "dimension" },
        "2xl": { "$value": "24px", "$type": "dimension" },
        "3xl": { "$value": "30px", "$type": "dimension" },
        "4xl": { "$value": "36px", "$type": "dimension" },
        "5xl": { "$value": "48px", "$type": "dimension" },
        "6xl": { "$value": "60px", "$type": "dimension" },
        "7xl": { "$value": "72px", "$type": "dimension" }
      },
      "tracking": {
        "tight": { "$value": "-0.02em", "$type": "dimension" },
        "normal": { "$value": "0em", "$type": "dimension" },
        "wide": { "$value": "0.02em", "$type": "dimension" },
        "wider": { "$value": "0.05em", "$type": "dimension" },
        "widest": { "$value": "0.1em", "$type": "dimension" }
      },
      "leading": {
        "none": { "$value": 1, "$type": "number" },
        "tight": { "$value": 1.25, "$type": "number" },
        "snug": { "$value": 1.375, "$type": "number" },
        "normal": { "$value": 1.5, "$type": "number" },
        "relaxed": { "$value": 1.625, "$type": "number" },
        "loose": { "$value": 2, "$type": "number" }
      }
    },
    "role": {
      "display": { "size": "5xl", "weight": "bold", "tracking": "tight", "leading": "tight" },
      "h1": { "size": "4xl", "weight": "bold", "tracking": "tight", "leading": "tight" },
      "h2": { "size": "3xl", "weight": "semibold", "tracking": "tight", "leading": "snug" },
      "h3": { "size": "2xl", "weight": "semibold", "tracking": "normal", "leading": "snug" },
      "h4": { "size": "xl", "weight": "semibold", "tracking": "normal", "leading": "normal" },
      "body": { "size": "base", "weight": "regular", "tracking": "normal", "leading": "normal" },
      "small": { "size": "sm", "weight": "regular", "tracking": "normal", "leading": "normal" },
      "meta": { "size": "xs", "weight": "regular", "tracking": "wide", "leading": "normal" },
      "label": { "size": "sm", "weight": "medium", "tracking": "normal", "leading": "none" },
      "code": {
        "size": "sm",
        "weight": "regular",
        "tracking": "normal",
        "leading": "relaxed",
        "mono": true
      }
    }
  }
}
