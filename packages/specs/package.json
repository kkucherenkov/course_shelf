{
  "name": "@app/specs",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Single source of truth for API contracts (OpenAPI + AsyncAPI)",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./openapi.json": "./dist/openapi.json"
  },
  "files": [
    "src",
    "openapi",
    "asyncapi",
    "dist"
  ],
  "scripts": {
    "validate": "node --experimental-strip-types scripts/validate.ts",
    "bundle": "node --experimental-strip-types scripts/bundle.ts",
    "codegen": "node --experimental-strip-types scripts/codegen.ts",
    "contract-test": "node --experimental-strip-types scripts/contract-test.ts",
    "diff": "node --experimental-strip-types scripts/diff.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-typescript": "^7.5.0"
  },
  "devDependencies": {
    "@app/eslint-config": "workspace:*",
    "@app/tsconfig": "workspace:*",
    "@asyncapi/cli": "^6.0.0",
    "@hey-api/openapi-ts": "^0.96.0",
    "@openapitools/openapi-generator-cli": "^2.15.3",
    "@redocly/cli": "^1.28.1",
    "@types/node": "^25.6.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^6.0.3",
    "yaml": "^2.8.3"
  }
}
