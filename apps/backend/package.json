{
  "name": "@app/backend",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "App NestJS backend",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:db:push": "prisma db push --accept-data-loss",
    "prisma:studio": "prisma studio",
    "db:seed": "node --experimental-strip-types prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && pnpm db:seed",
    "auth:generate-schema": "better-auth generate --output prisma/schema.prisma"
  },
  "dependencies": {
    "@app/api-client-ts": "workspace:*",
    "@app/specs": "workspace:*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/cqrs": "^11.0.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/throttler": "^6.3.0",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@sentry/node": "^8.55.0",
    "better-auth": "^1.6.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dataloader": "^2.2.3",
    "express-openapi-validator": "^5.4.0",
    "firebase-admin": "^13.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9",
    "nestjs-i18n": "^10.7.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@app/eslint-config": "workspace:*",
    "@app/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@swc/core": "^1.15.26",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "prisma": "^7.7.0",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
