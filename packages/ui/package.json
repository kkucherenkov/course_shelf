{
  "name": "@app/ui",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Internal Vue 3 UI library layered on Nuxt UI v4, with colocated Storybook stories.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./components/*": "./src/components/*",
    "./composables/*": "./src/composables/*",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "audit:components": "node --experimental-strip-types scripts/audit-components.ts",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "vue-tsc --noEmit",
    "build": "vite build",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build -o storybook-static",
    "test:visual": "test-storybook --url http://127.0.0.1:6006",
    "test:visual:ci": "concurrently -k -s first -n \"sb,tests\" -c \"magenta,blue\" \"http-server storybook-static -p 6006 --silent\" \"wait-on tcp:6006 && pnpm test:visual\""
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@app/api-client-ts": "workspace:*",
    "@nuxt/ui": "^4.6.0"
  },
  "devDependencies": {
    "@app/eslint-config": "workspace:*",
    "@app/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/vue3": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@storybook/test-runner": "^0.24.0",
    "jest-image-snapshot": "^6.4.0",
    "@types/jest-image-snapshot": "^6.4.0",
    "@tailwindcss/vite": "^4.2.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.1.0",
    "happy-dom": "^20.9.0",
    "http-server": "^14.1.1",
    "playwright": "^1.49.0",
    "sass": "^1.83.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.5",
    "vue": "^3.5.13",
    "vue-router": "^5.0.4",
    "vue-tsc": "^3.2.0"
  }
}
