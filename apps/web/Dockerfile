# Production image for the Nuxt SPA.
#
# Stage 1 builds the static SPA (`nuxt generate` → `.output/public/`).
# Stage 2 serves it with nginx + injects per-deployment config at boot.
#
# The SPA is built ONCE and configured per-deployment via
# `/_app-config.js` — a tiny script generated by the entrypoint from
# environment variables. The runtime-config plugin in
# `apps/web/app/plugins/00.runtime-config.client.ts` reads
# `window.__APP_CONFIG__` from that script and overrides
# `runtimeConfig.public.apiBaseUrl` / `authBaseUrl` before any other
# plugin loads.
#
# Build:    docker build -f apps/web/Dockerfile -t courseshelf/web:latest .
# (build context = repo root)

# ─── Stage 1 — generate static SPA ────────────────────────────────────────
FROM node:24-alpine AS build

RUN apk add --no-cache libc6-compat \
    && corepack enable

WORKDIR /workspace

ENV CI=1 \
    PNPM_HOME=/root/.local/share/pnpm \
    PATH=/root/.local/share/pnpm:$PATH

# Cache-friendly install: lockfile + manifests first.
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY apps/backend/package.json apps/backend/
COPY apps/web/package.json apps/web/
COPY packages/api-client-ts/package.json packages/api-client-ts/
COPY packages/design-tokens/package.json packages/design-tokens/
COPY packages/eslint-config/package.json packages/eslint-config/
COPY packages/specs/package.json packages/specs/
COPY packages/tsconfig/package.json packages/tsconfig/
COPY packages/ui/package.json packages/ui/

# `--ignore-scripts` skips lifecycle hooks at install time; we invoke
# them explicitly after the source is copied (the root `prepare` script
# would otherwise try to build @app/api-client-ts before its source is
# available).
RUN pnpm install --frozen-lockfile --ignore-scripts

COPY . .

# Bundle the spec, regen the TS client (the SPA imports its types), and
# generate the static SPA. apiBaseUrl / authBaseUrl are placeholders here;
# the runtime-config plugin overrides them at boot from /_app-config.js.
RUN pnpm --filter @app/specs bundle \
    && pnpm --filter @app/api-client-ts build \
    && NUXT_PUBLIC_API_BASE_URL=__RUNTIME__ \
       NUXT_PUBLIC_AUTH_BASE_URL=__RUNTIME__ \
       pnpm --filter @app/web generate

# ─── Stage 2 — serve ─────────────────────────────────────────────────────
# nginx-unprivileged ships with the `nginx` user pre-configured, the pid
# file in /tmp, and a default listen on 8080 — no privileged port to
# bind, no root needed at runtime. The proxy upstream points at :8080
# (see docker/nginx/prod.conf).
FROM nginxinc/nginx-unprivileged:1.27-alpine AS runtime

# Informational only — the SPA is built once and configured per-deployment
# via /_app-config.js, so APP_VERSION never affects the bundle. The release
# workflow still passes `--build-arg APP_VERSION=<semver>` so `docker
# inspect` exposes the released version.
ARG APP_VERSION=0.0.0-dev
ENV APP_VERSION=${APP_VERSION}

# Root needed only for the install + COPY layers; we drop back to nginx
# (the image's default) before CMD runs.
USER root

# `gettext` provides envsubst (used by the entrypoint to expand env vars
# into the static config script).
RUN apk add --no-cache gettext

# Static SPA payload.
COPY --from=build /workspace/apps/web/.output/public /usr/share/nginx/html

# nginx site config + entrypoint that templates _app-config.js from env.
COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf
COPY apps/web/docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh \
    && chown -R nginx:nginx /usr/share/nginx/html

USER nginx

EXPOSE 8080

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
