# Release environment for the image-pulling deployment path.
#
# Copy this file to `.env` next to the downloaded `compose-release-vX.Y.Z.yml`
# and fill in the `change-me` markers — compose will fail loudly on any
# secret that's still missing.
#
# Pull + start:
#   docker compose --env-file .env -f compose-release-vX.Y.Z.yml pull
#   docker compose --env-file .env -f compose-release-vX.Y.Z.yml up -d
#
# Browse to http://<your-host>:${PROXY_PORT}.

# ─── Image source ───────────────────────────────────────────────────────────
# The release workflow renders compose-release-vX.Y.Z.yml with RELEASE_TAG
# already pinned to that version. Override here only if you want to point a
# running stack at `:latest` or another tag without re-downloading the file.
RELEASE_TAG=latest
REGISTRY=code.homelab.local
REGISTRY_NAMESPACE=kkucherenkov

# ─── Public-facing URL ──────────────────────────────────────────────────────
# The single origin browsers will hit. Set to the URL the proxy is reachable
# at — scheme + port if non-default. The web service bakes this into
# /_app-config.js at boot, and the backend uses it for CORS + Better Auth.
PUBLIC_BASE_URL=http://localhost:8080

# Host port for the nginx proxy. Inside docker the service listens on
# port 80; this variable controls the host-side mapping.
PROXY_PORT=8080

# ─── Course data on disk ────────────────────────────────────────────────────
# Absolute host path containing your course folders. Mounted read-only
# at /data/courses inside the backend.
COURSES_PATH=/srv/courseshelf/courses

# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_DB=courseshelf
POSTGRES_USER=courseshelf
POSTGRES_PASSWORD=change-me-pick-a-strong-one

# ─── Better Auth ────────────────────────────────────────────────────────────
# Session signing secret. Generate with `openssl rand -hex 32`.
BETTER_AUTH_SECRET=change-me-32-bytes-hex
AUTH_SELF_REGISTRATION=false
AUTH_EMAIL_VERIFICATION=false

# ─── Centrifugo (realtime) ──────────────────────────────────────────────────
# JSON-array of allowed browser origins. Defaults to `["${PUBLIC_BASE_URL}"]`
# when unset; override only if you serve the SPA from multiple origins.
# CENTRIFUGO_ALLOWED_ORIGINS=["https://courseshelf.example.com"]

# Backend → Centrifugo publishing key.
CENTRIFUGO_API_KEY=change-me-centrifugo-api-key
# HMAC secret — used to sign client tokens. Different from the API key.
CENTRIFUGO_TOKEN_HMAC_SECRET=change-me-centrifugo-hmac-secret
# Token TTL in seconds. 5 minutes is plenty for re-issue cycles.
CENTRIFUGO_TOKEN_TTL_SECONDS=300
# Centrifugo log level — `info` is fine for prod; flip to `debug` when triaging.
CENTRIFUGO_LOG_LEVEL=info
