# Production environment for self-hosted CourseShelf.
# Copy this file to `.env.production` at the repo root and fill in the
# `?:` markers — those are the values compose will fail loudly on if
# missing. Defaults are filled in for non-secret toggles.
#
#   docker compose --env-file .env.production -f docker/compose.prod.yml up -d --build
#
# Browse to http://<your-host>:${PROXY_PORT}.

# ─── Public-facing URL ──────────────────────────────────────────────────────
# The single origin browsers will hit. Set to the URL the proxy is
# reachable at — including scheme + port if non-default. The web service
# bakes this into /_app-config.js at boot, and the backend uses it for
# CORS + Better Auth's session base URL.
PUBLIC_BASE_URL=http://localhost:8080

# Host port for the nginx proxy. Inside docker the service listens on
# port 80; this variable controls the host-side mapping.
PROXY_PORT=8080

# ─── Course data on disk ────────────────────────────────────────────────────
# Absolute host path containing your course folders. Mounted read-only
# at /data/courses inside the backend. Admins point libraries at any
# subdirectory of /data/courses from the SPA. Re-mount with a different
# host folder to swap content without rebuilding any image.
COURSES_PATH=/srv/courseshelf/courses

# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_DB=courseshelf
POSTGRES_USER=courseshelf
POSTGRES_PASSWORD=change-me-pick-a-strong-one

# ─── Better Auth ────────────────────────────────────────────────────────────
# Session signing secret. Generate with `openssl rand -hex 32`.
BETTER_AUTH_SECRET=change-me-32-bytes-hex

# Self-registration: when false, the SPA hides /sign-up and the only way
# to add users is via the admin Users page (in chunk 3) or by setting
# AUTH_SELF_REGISTRATION=true temporarily.
AUTH_SELF_REGISTRATION=false

# Email verification (placeholder — no SMTP wired yet). When false, the
# sign-up wizard skips the 6-digit-code step.
AUTH_EMAIL_VERIFICATION=false

# ─── Centrifugo (realtime) ──────────────────────────────────────────────────
# API key — used by the backend to publish to channels.
CENTRIFUGO_API_KEY=change-me-centrifugo-api-key
# HMAC secret — used to sign client tokens. Different from the API key.
CENTRIFUGO_TOKEN_HMAC_SECRET=change-me-centrifugo-hmac-secret
# Token TTL in seconds. 5 minutes is plenty for re-issue cycles.
CENTRIFUGO_TOKEN_TTL_SECONDS=300
