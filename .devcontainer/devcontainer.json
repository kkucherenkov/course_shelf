{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "boilerplate",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:24-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-extra/features/pnpm:2": {
      "version": "10.33.0"
    },
    "ghcr.io/devcontainers-extra/features/flutter:1": {
      "version": "3.41.0"
    }
  },
  "forwardPorts": [3000, 3001, 3200, 5432, 6379, 8000],
  "portsAttributes": {
    "3000": { "label": "backend (NestJS)" },
    "3001": { "label": "web (Nuxt)" },
    "3200": { "label": "grafana (otel-lgtm)" },
    "5432": { "label": "postgres" },
    "6379": { "label": "redis" },
    "8000": { "label": "centrifugo" }
  },
  "postCreateCommand": "pnpm install --frozen-lockfile && pnpm spec:codegen",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "stylelint.vscode-stylelint",
        "Vue.volar",
        "Dart-Code.dart-code",
        "Dart-Code.flutter",
        "Prisma.prisma",
        "bradlc.vscode-tailwindcss",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "eslint.workingDirectories": [
          { "pattern": "apps/*" },
          { "pattern": "packages/*" }
        ]
      }
    }
  },
  "remoteEnv": {
    "PNPM_HOME": "/home/node/.local/share/pnpm"
  }
}
