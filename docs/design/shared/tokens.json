  "media": {
    "$description": "Colours for media surfaces: the video plane and anything drawn on top of video or cover artwork.\nDeliberately THEME-INDEPENDENT — emitted once under `:root`, never per theme, unlike `color.*`.\nVideo is dark in every theme and cover art is arbitrary, so on-media white must stay white in\nlight mode too; flipping these with the theme would make controls vanish into the footage.\nDo not use these for regular chrome — use `color.text.*` / `color.surface.*`, which do flip.",
    "stage": {
      "$value": "#000",
      "$type": "color",
      "$description": "The video plane itself — letterbox bars behind non-16:9 footage, and notches cut back to it (e.g. chapter ticks on a scrubber)"
    },
    "placeholderFrom": {
      "$value": "#1a1d22",
      "$type": "color",
      "$description": "Start of the 135deg gradient standing in for footage that has not loaded"
    },
    "placeholderTo": {
      "$value": "#0a0c10",
      "$type": "color",
      "$description": "End of the placeholder gradient"
    },
    "fg": {
      "$value": "#fff",
      "$type": "color",
