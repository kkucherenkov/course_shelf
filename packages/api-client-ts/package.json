{
  "name": "@app/api-client-ts",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Generated HTTP client for the App API (TypeScript). DO NOT EDIT BY HAND — regenerate via `pnpm spec:codegen`.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src --no-warn-ignored",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1"
  },
  "devDependencies": {
    "@app/eslint-config": "workspace:*",
    "@app/tsconfig": "workspace:*",
    "typescript": "^6.0.3"
  }
}
