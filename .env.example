# ─── Local-dev environment ──────────────────────────────────────────────────
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
#
# Most of these are defaulted inside docker/compose.yml for the local stack.
# You only need this file when running services outside Docker (e.g. `pnpm
# --filter @app/backend dev` against a remote DB) or when overriding secrets.
#
# The backend AppConfig (apps/backend/src/common/config/app-config.ts) treats
# anything marked "required" as fatal at boot.

# ─── Backend ────────────────────────────────────────────────────────────────

# required — Postgres connection string
DATABASE_URL=postgresql://app:app@localhost:5432/app

# required — Redis (queues, rate limits, cache)
REDIS_URL=redis://localhost:6379/0

# required — Better Auth session signing. Generate with `openssl rand -hex 32`.
BETTER_AUTH_SECRET=change-me-32-bytes-hex
# Public base URL of the backend (scheme + host + port, no trailing slash).
BETTER_AUTH_URL=http://localhost:3000
# Mount path of the Better Auth handler inside URI versioning.
BETTER_AUTH_BASE_PATH=/api/v1/auth
# Public auth surface toggles — read by GET /admin/instance.
# Self-registration: when false, the SPA hides /sign-up and redirects to /sign-in.
AUTH_SELF_REGISTRATION=true
# Email verification: when true, the sign-up wizard renders the 6-digit-code step
# (mirrors Better Auth's emailVerification plugin toggle).
AUTH_EMAIL_VERIFICATION=false

# required — Centrifugo realtime bridge
CENTRIFUGO_API_URL=http://localhost:8000/api
CENTRIFUGO_API_KEY=change-me-centrifugo-api-key
CENTRIFUGO_TOKEN_HMAC_SECRET=change-me-centrifugo-hmac-secret
CENTRIFUGO_TOKEN_TTL_SECONDS=300

# CORS — comma-separated list of allowed origins for the web app.
# 8080 is the nginx proxy (canonical SPA origin), 3001 is the bare Nuxt
# dev server kept whitelisted so devs can bypass the proxy if they need to.
CORS_ORIGINS=http://localhost:8080,http://localhost:3001

# OpenTelemetry collector endpoint (HTTP/protobuf). Leave blank to disable.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# optional — Sentry DSN. Leave blank to disable.
SENTRY_DSN=

# Server runtime
NODE_ENV=development
PORT=3000

# ─── Web (Nuxt) ─────────────────────────────────────────────────────────────

# Public URLs the browser hits. Must be reachable from the browser, not from
# inside Docker. Defaults point at the nginx proxy (port 8080) so the SPA
# and API share a single origin — no CORS, no CORP, no preflights. Override
# to http://localhost:3000 if you're hitting the backend directly.
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NUXT_PUBLIC_AUTH_BASE_URL=http://localhost:8080

# ─── Mobile (Flutter) ───────────────────────────────────────────────────────
# Flutter reads API base URL from --dart-define at build time, not from .env.
# See apps/mobile/README.md.
