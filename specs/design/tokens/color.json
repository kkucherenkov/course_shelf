{
  "$description": "Semantic color tokens — CourseShelf brand (warm neutrals + amber accent).",
  "color": {
    "brand": {
      "accent": {
        "light": { "$value": "#9C6612", "$type": "color" },
        "dark": { "$value": "#C8821C", "$type": "color" }
      },
      "accentHover": {
        "light": { "$value": "#6E480C", "$type": "color" },
        "dark": { "$value": "#E0A23B", "$type": "color" }
      },
      "accentActive": {
        "light": { "$value": "#6E480C", "$type": "color" },
        "dark": { "$value": "#E0A23B", "$type": "color" }
      },
      "accentFg": {
        "light": { "$value": "#FFFFFF", "$type": "color" },
        "dark": { "$value": "#15130C", "$type": "color" }
      },
      "accentSubtle": {
        "$description": "Solid approximation of accentSoft over the surface — used when alpha-on-surface is not desired.",
        "light": { "$value": "#F5F0E7", "$type": "color" },
        "dark": { "$value": "#2E2620", "$type": "color" }
      },
      "accentSoft": {
        "$description": "Translucent accent fill (alpha) — for selected rows, soft highlights, and primary input focus glow.",
        "light": { "$value": "rgba(156, 102, 18, 0.10)", "$type": "color" },
        "dark": { "$value": "rgba(200, 130, 28, 0.14)", "$type": "color" }
      }
    },
    "surface": {
      "page": {
        "light": { "$value": "#FAFAF7", "$type": "color" },
        "dark": { "$value": "#0E0F12", "$type": "color" }
      },
      "surface": {
        "light": { "$value": "#FFFFFF", "$type": "color" },
        "dark": { "$value": "#15171B", "$type": "color" }
      },
      "raised": {
        "light": { "$value": "#F4F3EE", "$type": "color" },
        "dark": { "$value": "#1A1C20", "$type": "color" }
      },
      "overlay": {
        "light": { "$value": "#EAE8E1", "$type": "color" },
        "dark": { "$value": "#22252B", "$type": "color" }
      },
      "skeletonBase": {
        "light": { "$value": "#EAE8E1", "$type": "color" },
        "dark": { "$value": "#1F2228", "$type": "color" }
      },
      "skeletonShine": {
        "light": { "$value": "#F4F3EE", "$type": "color" },
        "dark": { "$value": "#2A2E36", "$type": "color" }
      }
    },
    "border": {
      "default": {
        "light": { "$value": "#D9D5C9", "$type": "color" },
        "dark": { "$value": "#2D3037", "$type": "color" }
      },
      "strong": {
        "light": { "$value": "#BBB4A2", "$type": "color" },
        "dark": { "$value": "#454952", "$type": "color" }
      },
      "focus": {
        "light": { "$value": "#C8821C", "$type": "color" },
        "dark": { "$value": "#E0A23B", "$type": "color" }
      }
    },
    "text": {
      "fg": {
        "light": { "$value": "#211E15", "$type": "color" },
        "dark": { "$value": "#E8EAEE", "$type": "color" }
      },
      "loud": {
        "$description": "Strongest text — used for headings and tab/seg selected states.",
        "light": { "$value": "#15130C", "$type": "color" },
        "dark": { "$value": "#F5F6F8", "$type": "color" }
      },
      "secondary": {
        "$description": "Muted body text (alias: --text-muted in the prototype).",
        "light": { "$value": "#5C5644", "$type": "color" },
        "dark": { "$value": "#9CA0A8", "$type": "color" }
      },
      "tertiary": {
        "$description": "Subtle annotations / placeholder text (alias: --text-subtle in the prototype).",
        "light": { "$value": "#8E8773", "$type": "color" },
        "dark": { "$value": "#6B6F78", "$type": "color" }
      },
      "disabled": {
        "light": { "$value": "#BBB4A2", "$type": "color" },
        "dark": { "$value": "#454952", "$type": "color" }
      },
      "inverse": {
        "$description": "Text on inverse surfaces (light text in dark mode and vice versa).",
        "light": { "$value": "#F5F6F8", "$type": "color" },
        "dark": { "$value": "#15130C", "$type": "color" }
      },
      "link": {
        "light": { "$value": "#9C6612", "$type": "color" },
        "dark": { "$value": "#C8821C", "$type": "color" }
      }
    },
    "status": {
      "successFg": {
        "light": { "$value": "#2D6A63", "$type": "color" },
        "dark": { "$value": "#5BA89F", "$type": "color" }
      },
      "successSubtle": {
        "light": { "$value": "#E5F0EE", "$type": "color" },
        "dark": { "$value": "#1F2A28", "$type": "color" }
      },
      "successSoft": {
        "light": { "$value": "rgba(45, 106, 99, 0.12)", "$type": "color" },
        "dark": { "$value": "rgba(91, 168, 159, 0.14)", "$type": "color" }
      },
      "warningFg": {
        "light": { "$value": "#9C6612", "$type": "color" },
        "dark": { "$value": "#E0A23B", "$type": "color" }
      },
      "warningSubtle": {
        "light": { "$value": "#F5EAD8", "$type": "color" },
        "dark": { "$value": "#2E2620", "$type": "color" }
      },
      "warningSoft": {
        "light": { "$value": "rgba(156, 102, 18, 0.12)", "$type": "color" },
        "dark": { "$value": "rgba(224, 162, 59, 0.14)", "$type": "color" }
      },
      "errorFg": {
        "light": { "$value": "#A04434", "$type": "color" },
        "dark": { "$value": "#D26B5C", "$type": "color" }
      },
      "errorSubtle": {
        "light": { "$value": "#F4DED9", "$type": "color" },
        "dark": { "$value": "#2E1F1B", "$type": "color" }
      },
      "errorSoft": {
        "light": { "$value": "rgba(160, 68, 52, 0.12)", "$type": "color" },
        "dark": { "$value": "rgba(210, 107, 92, 0.14)", "$type": "color" }
      },
      "infoFg": {
        "light": { "$value": "#4F5694", "$type": "color" },
        "dark": { "$value": "#8189C7", "$type": "color" }
      },
      "infoSubtle": {
        "light": { "$value": "#E1E3F2", "$type": "color" },
        "dark": { "$value": "#1F2230", "$type": "color" }
      },
      "infoSoft": {
        "light": { "$value": "rgba(79, 86, 148, 0.12)", "$type": "color" },
        "dark": { "$value": "rgba(129, 137, 199, 0.14)", "$type": "color" }
      }
    },
    "vertical": {}
  }
}
